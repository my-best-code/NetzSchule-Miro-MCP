{
  "name": "@my-best-code/netzschule-miro-mcp",
  "version": "0.9.0",
  "description": "A Model Context Protocol server to connect to the MIRO Whiteboard Application. Supports board filtering by owner/team.",
  "author": "Dmitri Konnov (https://github.com/DmitriKonnovNN)",
  "license": "Apache-2.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "mcp-miro": "./build/index.js"
  },
  "files": [
    "build",
    "resources"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/my-best-code/NetzSchule-Miro-MCP.git"
  },
  "homepage": "https://github.com/my-best-code/NetzSchule-Miro-MCP#readme",
  "bugs": {
    "url": "https://github.com/my-best-code/NetzSchule-Miro-MCP/issues"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "build:lambda": "esbuild src/rest/lambda.ts --bundle --platform=node --target=node24 --outfile=dist/lambda.js --format=cjs",
    "build:mcp-lambda": "esbuild src/mcp/lambda.ts --bundle --platform=node --target=node24 --outfile=dist/mcp-lambda.js --format=cjs --loader:.md=text",
    "build:lambdas": "npm run build:lambda && npm run build:mcp-lambda",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/yargs": "^17.0.35",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
